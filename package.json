    "js-cookie": "^3.0.5",
    "lucide-react": "^0.546.0",
    "prop-types": "^15.8.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^6.0.0",
    "react-helmet-async": "^2.0.4",
    "react-hook-form": "^7.62.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.8.2",
    "zod": "^4.1.5"
